{
  "layer": "top",
  "position": "top",
  "height": 24,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["cpu", "memory", "battery","pulseaudio", "network"],

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "hyprctl dispatch workspace {id}"
  },

  "clock": {
    "format": "яАЧ  {:%H:%M}",
    "tooltip-format": "{:%A, %d %B %Y}"
  },

  "cpu": {
    "format": "яЛЫ  {usage}%",
    "tooltip": true
  },

  "memory": {
    "format": "яГЙ  {used}G",
    "tooltip": false
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  },

  "network": {
    "format-wifi": "яЗл  {essid}",
    "format-ethernet": "яГБ  {ifname}",
    "format-disconnected": "яДз"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-icons": {
      "default": ["яАж", "яАз", "яАи"]
    },
    "on-click": "pavucontrol",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
  }
}
